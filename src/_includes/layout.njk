<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ title or (item.titulo + " — Noticias · Telar") }}</title>
<meta name="description" content="{{ description or item.resumen }}">
<meta name="robots" content="index, follow">
<link rel="canonical" href="https://www.telar.es{{ page.url }}"> <!-- TODO: sustituir por el dominio real antes de publicar -->

<!-- Open Graph / redes sociales -->
<meta property="og:type" content="website">
<meta property="og:title" content="{{ ogTitle or title or item.titulo }}">
<meta property="og:description" content="{{ ogDescription or description or item.resumen }}">
<meta property="og:locale" content="es_ES">
<meta property="og:url" content="https://www.telar.es{{ page.url }}"> <!-- TODO: sustituir por el dominio real -->
<meta name="twitter:card" content="summary">

<link rel="icon" type="image/svg+xml" href="/assets/favicon.svg">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Archivo:ital,wdth,wght@0,62..125,100..900&family=Source+Serif+4:ital,opsz,wght@0,8..60,200..900;1,8..60,200..900&family=Spline+Sans+Mono:wght@300..700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/assets/styles.css">
</head>
<body>

<div class="page-intro" aria-hidden="true">
  <span class="page-intro-panel page-intro-panel--a"></span>
  <span class="page-intro-panel page-intro-panel--b"></span>
</div>
<div class="scroll-progress" aria-hidden="true"></div>
<div class="bg-grid" aria-hidden="true"></div>

<div class="wrap">

  {%- set homePrefix = '' if page.url == '/' else '/' %}

  <!-- ============ HEADER ============ -->
  <header>
    <a href="/" class="logo" style="text-decoration:none;color:inherit">
      <div class="logo-mark" aria-hidden="true">
        <span class="h1"></span>
        <span class="h2"></span>
        <span class="v"></span>
      </div>
      <span class="logo-text">Telar</span>
    </a>
    <nav>
      <a class="nav-link" href="{{ homePrefix }}#proceso">Proceso</a>
      <a class="nav-link" href="{{ homePrefix }}#sectores">Sectores</a>
      <a class="nav-link" href="{{ homePrefix }}#escenarios">Escenarios</a>
      <a class="nav-link{% if '/noticias/' in page.url %} active{% endif %}" href="/noticias/">Noticias</a>
      <a class="btn-cta" href="{{ homePrefix }}#contacto">Agendar llamada</a>
      <button id="theme-toggle" class="theme-toggle" type="button" title="Cambiar tema">Oscuro</button>
    </nav>
  </header>

  {{ content | safe }}

  <!-- ============ FOOTER ============ -->
  <footer>
    <div class="footer-brand">
      <span class="name">Telar</span>
      <p>Agentes de IA que se ocupan de lo mecánico y devuelven tiempo a las personas. Siempre con supervisión humana.</p>
    </div>
    <div class="footer-col">
      <span class="label">Contacto</span>
      <!-- TODO: placeholders — sustituir por los datos reales antes de publicar -->
      <a href="mailto:hola@telar.es">hola@telar.es</a>
      <a href="tel:+34910000000">+34 910 000 000</a>
    </div>
    <div class="footer-col">
      <span class="label">Estudio</span>
      <!-- TODO: placeholder — sustituir por la ciudad real -->
      <span class="muted">Madrid, España</span>
      <span class="muted">© 2026 Telar</span>
    </div>
  </footer>

</div>

<a href="{{ homePrefix }}#contacto" class="sticky-cta">Agendar auditoría →</a>

<script src="/assets/script.js"></script>
</body>
</html>
