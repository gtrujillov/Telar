{%- set lang = lang or 'es' -%}
{%- set L = t[lang] -%}
<!DOCTYPE html>
<html lang="{{ L.htmlLang or lang }}">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ title or (item.titulo + " — Noticias · Yuulia") }}</title>
<meta name="description" content="{{ description or item.resumen }}">
<meta name="robots" content="index, follow">
<meta name="theme-color" content="#F4F6F5" media="(prefers-color-scheme: light)">
<meta name="theme-color" content="#1B222D" media="(prefers-color-scheme: dark)">
<link rel="canonical" href="{{ site.url }}{{ page.url }}">
{%- if page.url == '/' or page.url == '/en/' or page.url == '/pt/' %}
<link rel="alternate" hreflang="es" href="{{ site.url }}/">
<link rel="alternate" hreflang="en" href="{{ site.url }}/en/">
<link rel="alternate" hreflang="pt-PT" href="{{ site.url }}/pt/">
<link rel="alternate" hreflang="x-default" href="{{ site.url }}/">
{%- endif %}

<!-- Open Graph / redes sociales -->
<meta property="og:type" content="{{ ogType or "website" }}">
<meta property="og:site_name" content="Yuulia">
<meta property="og:title" content="{{ ogTitle or title or item.titulo }}">
<meta property="og:description" content="{{ ogDescription or description or item.resumen }}">
<meta property="og:locale" content="{{ L.ogLocale }}">
<meta property="og:url" content="{{ site.url }}{{ page.url }}">
<meta property="og:image" content="{{ site.url }}/assets/images/video-poster.jpg">
<meta property="og:image:width" content="1920">
<meta property="og:image:height" content="1080">
<meta property="og:image:alt" content="Yuulia — consultora de automatización de procesos con IA">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ ogTitle or title or item.titulo }}">
<meta name="twitter:description" content="{{ ogDescription or description or item.resumen }}">
<meta name="twitter:image" content="{{ site.url }}/assets/images/video-poster.jpg">

<link rel="icon" type="image/svg+xml" href="/assets/favicon.svg">
<link rel="apple-touch-icon" sizes="180x180" href="/assets/images/apple-touch-icon.png">

{% if analytics.ga4Id %}
<!-- Google Analytics 4: solo se carga si el visitante acepta las cookies (ver script.js) -->
<script>window.YUULIA_GA4_ID = "{{ analytics.ga4Id }}";</script>
{% endif %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Archivo:ital,wdth,wght@0,62..125,100..900&family=Inter:opsz,wght@14..32,100..900&family=Spline+Sans+Mono:wght@300..700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/assets/styles.css">

<!-- TODO: añadir telephone y address cuando haya datos reales que publicar -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "Yuulia",
  "description": "{{ L.schemaDesc }}",
  "url": "{{ site.url }}/",
  "logo": "{{ site.url }}/assets/images/yuulia-logo.png",
  "image": "{{ site.url }}/assets/images/video-poster.jpg",
  "areaServed": { "@type": "Country", "name": "España" },
  "email": "info@yuulia.com"
}
</script>
</head>
<body>

<a href="#main" class="skip-link">{{ L.skip }}</a>

<div class="scroll-progress" aria-hidden="true"></div>
<div class="bg-scene" aria-hidden="true">
  <span class="aurora aurora-1"></span>
  <span class="aurora aurora-2"></span>
  <span class="aurora aurora-3"></span>
  <span class="depth"></span>
  <span class="grain"></span>
</div>

<div class="wrap">

  {%- set langHome = '/' if lang == 'es' else '/' + lang + '/' %}
  {%- set homePrefix = '' if page.url == langHome else langHome %}

  <!-- ============ HEADER ============ -->
  <header>
    <a href="/" class="logo" style="text-decoration:none;color:inherit">
      <svg class="logo-mark" viewBox="0 0 100 100" aria-hidden="true" focusable="false">
        <path d="M9 9 L50 53 L91 9" fill="none" stroke="var(--anil)" stroke-width="11" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M50 53 L50 94" fill="none" stroke="var(--grana)" stroke-width="11" stroke-linecap="round"/>
      </svg>
      <span class="logo-text">Yuulia</span>
    </a>
    <button id="nav-toggle" class="nav-toggle" type="button" aria-expanded="false" aria-controls="site-nav" aria-label="Abrir menú">
      <span></span><span></span><span></span>
    </button>
    <nav id="site-nav">
      <a class="nav-link" href="{{ homePrefix }}#proceso">{{ L.nav.proceso }}</a>
      <a class="nav-link" href="{{ homePrefix }}#sectores">{{ L.nav.sectores }}</a>
      {%- if lang == 'es' %}
      <a class="nav-link{% if '/guias/' in page.url %} active{% endif %}" href="/guias/">{{ L.nav.guias }}</a>
      <a class="nav-link{% if '/noticias/' in page.url %} active{% endif %}" href="/noticias/">{{ L.nav.noticias }}</a>
      {%- endif %}
      <a class="btn-cta" href="{{ homePrefix }}#contacto">{{ L.nav.cta }}</a>
      <span class="lang-switch" aria-label="Idioma">
        <a href="/" {% if lang == 'es' %}class="active" aria-current="true"{% endif %} lang="es" hreflang="es">ES</a>
        <a href="/en/" {% if lang == 'en' %}class="active" aria-current="true"{% endif %} lang="en" hreflang="en">EN</a>
        <a href="/pt/" {% if lang == 'pt' %}class="active" aria-current="true"{% endif %} lang="pt" hreflang="pt">PT</a>
      </span>
      <button id="theme-toggle" class="theme-toggle" type="button" title="{{ L.temaTitulo }}" data-label-dark="{{ L.temaOscuro }}" data-label-light="{{ L.temaClaro }}">{{ L.temaOscuro }}</button>
    </nav>
  </header>

  <main id="main">
  {{ content | safe }}
  </main>

  <!-- ============ FOOTER ============ -->
  <footer>
    <div class="footer-brand">
      <span class="name">
        <svg class="logo-mark" viewBox="0 0 100 100" aria-hidden="true" focusable="false">
          <path d="M9 9 L50 53 L91 9" fill="none" stroke="var(--anil)" stroke-width="11" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M50 53 L50 94" fill="none" stroke="var(--grana)" stroke-width="11" stroke-linecap="round"/>
        </svg>
        Yuulia
      </span>
      <p>{{ L.footer.brand }}</p>
    </div>
    <div class="footer-col">
      <span class="label">{{ L.footer.empresa }}</span>
      <a href="{{ homePrefix }}#proceso">{{ L.footer.comoTrabajamos }}</a>
      <a href="{{ homePrefix }}#sectores">{{ L.footer.sectores }}</a>
      {%- if lang == 'es' %}
      <a href="/guias/">{{ L.footer.guias }}</a>
      <a href="/noticias/">{{ L.footer.noticias }}</a>
      {%- endif %}
    </div>
    <div class="footer-col">
      <span class="label">{{ L.footer.contacto }}</span>
      <!-- TODO: activar Email Routing en Cloudflare para que info@yuulia.com reciba correo.
           Teléfono y ciudad retirados hasta tener datos reales (no publicar placeholders). -->
      <a href="mailto:info@yuulia.com">info@yuulia.com</a>
    </div>
    <div class="footer-col">
      <span class="label">{{ L.footer.legal }}</span>
      <!-- TODO: páginas con contenido de plantilla — revisar con un asesor legal antes de publicar -->
      <a href="/privacidad/">{{ L.footer.privacidad }}</a>
      <a href="/cookies/">{{ L.footer.cookies }}</a>
      <a href="/aviso-legal/">{{ L.footer.avisoLegal }}</a>
      {% if analytics.ga4Id %}<button type="button" class="footer-cookies-btn" data-cookies-abrir>{{ L.cookiesUi.gestionar }}</button>{% endif %}
    </div>
    <p class="footer-copy">© 2026 Yuulia · v{{ site.version }}</p>
  </footer>

</div>

<a href="{{ homePrefix }}#contacto" class="sticky-cta">{{ L.stickyCta }}</a>

{% if analytics.ga4Id %}
<div id="cookie-banner" class="cookie-banner" role="dialog" aria-live="polite" aria-label="{{ L.cookiesUi.label }}" hidden>
  <p>{{ L.cookiesUi.aviso }} <a href="/cookies/">{{ L.cookiesUi.masInfo }}</a>.</p>
  <div class="cookie-banner-botones">
    <button type="button" id="cookies-rechazar" class="cookie-btn">{{ L.cookiesUi.rechazar }}</button>
    <button type="button" id="cookies-aceptar" class="cookie-btn cookie-btn--primario">{{ L.cookiesUi.aceptar }}</button>
  </div>
</div>
{% endif %}

<script src="/assets/script.js"></script>
</body>
</html>
