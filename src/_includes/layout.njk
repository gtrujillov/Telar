<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ title or (item.titulo + " — Noticias · Yuulia") }}</title>
<meta name="description" content="{{ description or item.resumen }}">
<meta name="robots" content="index, follow">
<meta name="theme-color" content="#F4F6F5" media="(prefers-color-scheme: light)">
<meta name="theme-color" content="#1B222D" media="(prefers-color-scheme: dark)">
<link rel="canonical" href="{{ site.url }}{{ page.url }}">

<!-- Open Graph / redes sociales -->
<meta property="og:type" content="{{ ogType or "website" }}">
<meta property="og:site_name" content="Yuulia">
<meta property="og:title" content="{{ ogTitle or title or item.titulo }}">
<meta property="og:description" content="{{ ogDescription or description or item.resumen }}">
<meta property="og:locale" content="es_ES">
<meta property="og:url" content="{{ site.url }}{{ page.url }}">
<meta property="og:image" content="{{ site.url }}/assets/images/video-poster.jpg">
<meta property="og:image:width" content="1920">
<meta property="og:image:height" content="1080">
<meta property="og:image:alt" content="Yuulia — agentes de IA para pymes">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ ogTitle or title or item.titulo }}">
<meta name="twitter:description" content="{{ ogDescription or description or item.resumen }}">
<meta name="twitter:image" content="{{ site.url }}/assets/images/video-poster.jpg">

<link rel="icon" type="image/svg+xml" href="/assets/favicon.svg">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Archivo:ital,wdth,wght@0,62..125,100..900&family=Inter:opsz,wght@14..32,100..900&family=Spline+Sans+Mono:wght@300..700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/assets/styles.css">

<!-- TODO: email, teléfono y ciudad son placeholders (ver footer) — se reflejan aquí también; sustituir juntos antes de publicar -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "Yuulia",
  "description": "Yuulia diseña agentes de IA que automatizan las tareas repetitivas de pymes españolas: despachos profesionales, hostelería, comercio y empresas de servicios.",
  "url": "{{ site.url }}/",
  "logo": "{{ site.url }}/assets/favicon.svg",
  "image": "{{ site.url }}/assets/images/video-poster.jpg",
  "areaServed": { "@type": "Country", "name": "España" },
  "email": "hola@yuulia.com",
  "telephone": "+34910000000",
  "address": { "@type": "PostalAddress", "addressLocality": "Madrid", "addressCountry": "ES" }
}
</script>
</head>
<body>

<a href="#main" class="skip-link">Saltar al contenido</a>

<div class="page-intro" aria-hidden="true">
  <span class="page-intro-panel page-intro-panel--a"></span>
  <span class="page-intro-panel page-intro-panel--b"></span>
</div>
<div class="scroll-progress" aria-hidden="true"></div>
<div class="bg-mesh" aria-hidden="true">
  <span class="blob blob-1"></span>
  <span class="blob blob-2"></span>
  <span class="blob blob-3"></span>
  <span class="blob blob-4"></span>
</div>

<div class="wrap">

  {%- set homePrefix = '' if page.url == '/' else '/' %}

  <!-- ============ HEADER ============ -->
  <header>
    <a href="/" class="logo" style="text-decoration:none;color:inherit">
      <div class="logo-mark" aria-hidden="true">
        <span class="d1"></span>
        <span class="d2"></span>
        <span class="v"></span>
      </div>
      <span class="logo-text">Yuulia</span>
    </a>
    <button id="nav-toggle" class="nav-toggle" type="button" aria-expanded="false" aria-controls="site-nav" aria-label="Abrir menú">
      <span></span><span></span><span></span>
    </button>
    <nav id="site-nav">
      <a class="nav-link" href="{{ homePrefix }}#proceso">Proceso</a>
      <a class="nav-link" href="{{ homePrefix }}#por-que">Por qué Yuulia</a>
      <a class="nav-link" href="{{ homePrefix }}#sectores">Sectores</a>
      <a class="nav-link" href="{{ homePrefix }}#escenarios">Escenarios</a>
      <a class="nav-link" href="{{ homePrefix }}#preguntas">Preguntas</a>
      <a class="nav-link{% if '/guias/' in page.url %} active{% endif %}" href="/guias/">Guías</a>
      <a class="nav-link{% if '/noticias/' in page.url %} active{% endif %}" href="/noticias/">Noticias</a>
      <a class="btn-cta" href="{{ homePrefix }}#contacto">Agendar llamada</a>
      <button id="theme-toggle" class="theme-toggle" type="button" title="Cambiar tema">Oscuro</button>
    </nav>
  </header>

  <main id="main">
  {{ content | safe }}
  </main>

  <!-- ============ FOOTER ============ -->
  <footer>
    <div class="footer-brand">
      <span class="name">Yuulia</span>
      <p>Agentes de IA que se ocupan de lo mecánico y devuelven tiempo a las personas. Siempre con supervisión humana.</p>
    </div>
    <div class="footer-col">
      <span class="label">Empresa</span>
      <a href="{{ homePrefix }}#proceso">Cómo trabajamos</a>
      <a href="{{ homePrefix }}#sectores">Sectores</a>
      <a href="/guias/">Guías</a>
      <a href="/noticias/">Noticias</a>
    </div>
    <div class="footer-col">
      <span class="label">Contacto</span>
      <!-- TODO: placeholders — sustituir por los datos reales antes de publicar -->
      <a href="mailto:hola@yuulia.com">hola@yuulia.com</a>
      <a href="tel:+34910000000">+34 910 000 000</a>
      <!-- TODO: placeholder — sustituir por la ciudad real -->
      <span class="muted">Madrid, España</span>
    </div>
    <div class="footer-col">
      <span class="label">Legal</span>
      <!-- TODO: páginas con contenido de plantilla — revisar con un asesor legal antes de publicar -->
      <a href="/privacidad/">Privacidad</a>
      <a href="/cookies/">Cookies</a>
      <a href="/aviso-legal/">Aviso legal</a>
    </div>
    <p class="footer-copy">© 2026 Yuulia</p>
  </footer>

</div>

<a href="{{ homePrefix }}#contacto" class="sticky-cta">Agendar auditoría →</a>

<script src="/assets/script.js"></script>
</body>
</html>
