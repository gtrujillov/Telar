---
layout: layout.njk
pagination:
  data: noticias
  size: 1
  alias: item
permalink: "/noticias/{{ item.slug }}/"
ogType: article
---
<section class="labeled-section">
  <p class="eyebrow"><a href="/noticias/">Noticias</a> / {{ item.categoria }}</p>
  <div>
    <p class="noticia-articulo-fecha">{{ item.fecha }}</p>
    <h1 class="section-title">{{ item.titulo }}</h1>
    <p class="noticia-articulo-resumen">{{ item.resumen }}</p>

    <div class="noticia-articulo-fuente">
      <p>Este resumen es una curación de Yuulia. El artículo completo está en {{ item.fuente_nombre }}.</p>
      <a href="{{ item.fuente_url }}" class="btn-primary" target="_blank" rel="noopener noreferrer">Leer la noticia completa en {{ item.fuente_nombre }} ↗</a>
    </div>

    {%- if noticias | length > 1 %}
    <div class="noticia-articulo-otras">
      <p class="label">Más noticias</p>
      <ul>
        {%- for otra in noticias %}
        {%- if otra.slug != item.slug %}
        <li><a href="/noticias/{{ otra.slug }}/">{{ otra.titulo }}</a></li>
        {%- endif %}
        {%- endfor %}
      </ul>
    </div>
    {%- endif %}
  </div>
</section>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "NewsArticle",
  "headline": {{ item.titulo | dump | safe }},
  "description": {{ item.resumen | dump | safe }},
  "datePublished": "{{ item.fecha }}",
  "dateModified": "{{ item.fecha }}",
  "inLanguage": "es",
  "mainEntityOfPage": "{{ site.url }}/noticias/{{ item.slug }}/",
  "image": "{{ site.url }}/assets/images/video-poster.jpg",
  "author": { "@type": "Organization", "name": "Yuulia", "url": "{{ site.url }}/" },
  "publisher": { "@type": "Organization", "name": "Yuulia", "logo": { "@type": "ImageObject", "url": "{{ site.url }}/assets/images/yuulia-logo.png" } },
  "isBasedOn": {{ item.fuente_url | dump | safe }}
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "{{ site.url }}/" },
    { "@type": "ListItem", "position": 2, "name": "Noticias", "item": "{{ site.url }}/noticias/" },
    { "@type": "ListItem", "position": 3, "name": {{ item.titulo | dump | safe }} }
  ]
}
</script>
